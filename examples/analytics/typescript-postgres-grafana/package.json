{
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "start": "node --enable-source-maps dist/server.js",
    "dev": "tsup src/*.ts --watch --onSuccess \"node --enable-source-maps dist/server.js\"",
    "build": "tsup src/*.ts --minify --dts-resolve",
    "update": "yarn up -R '*' && yarn dedupe --strategy highest",
    "latest": "yarn npm-check-updates -i -m --packageManager yarn --install never && yarn install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.1",
    "reflect-metadata": "^0.1.13",
    "tsup": "^7.1.0",
    "typeorm": "^0.3.17",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "@swc/core": "^1.3.67",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.3",
    "npm-check-updates": "^20.0.0"
  }
}
